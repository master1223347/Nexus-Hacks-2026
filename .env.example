TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# For WhatsApp Sandbox: TWILIO_PHONE_NUMBER=whatsapp:+14155238886
# (the "whatsapp:" prefix is mandatory and must match the channel of
# whatever number you configure as the inbound sender on Twilio.)
TWILIO_PHONE_NUMBER=
# Slide-only display value, e.g. "silver-koala" — not used in code.
TWILIO_WHATSAPP_JOIN_CODE=
PORT=8000
PUBLIC_BASE_URL=
TWILIO_VALIDATE_SIGNATURE=false

# LLM providers (Pane 3)
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
WINGMAN_LLM_TIMEOUT_S=2.2
WINGMAN_LLM_ORCH_TIMEOUT_S=2.5
ANTHROPIC_API_KEY=

# Memory backend (Pane 3 — H3)
NIA_API_KEY=
NIA_ENDPOINT=
NIA_NAMESPACE=wingman_memory
